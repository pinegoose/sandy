#!/usr/bin/env bash
set -euo pipefail

SANDY_HOME="${SANDY_HOME:-$HOME/.sandy}"
COMPOSE_FILE="sandy-compose.yml"

usage() {
    cat <<EOF
Usage: sandy <command>

Commands:
  init      Set up sandy in the current project directory
  up        Start the dev container (default if no command given)
  down      Stop the dev container
  shell     Open a shell in the running container
  rebuild   Rebuild the container image from scratch
  destroy   Stop container, remove volumes, and remove sandy-compose.yml

EOF
    exit 1
}

require_compose() {
    if [[ ! -f "$COMPOSE_FILE" ]]; then
        echo "Error: $COMPOSE_FILE not found in current directory."
        echo "Run 'sandy init' first."
        exit 1
    fi
}

compose() {
    SANDY_HOME="$SANDY_HOME" HOST_HOME="$HOME" docker compose -f "$COMPOSE_FILE" "$@"
}

cmd_init() {
    if [[ ! -f "$SANDY_HOME/Dockerfile" ]]; then
        echo "Error: Sandy not installed. Run install.sh first."
        exit 1
    fi

    if [[ -f "$COMPOSE_FILE" ]]; then
        echo "$COMPOSE_FILE already exists, skipping."
    else
        cat > "$COMPOSE_FILE" <<'YAML'
services:
  sandy:
    build: ${SANDY_HOME}
    restart: unless-stopped
    env_file:
      - .sandy.env
    volumes:
      - home:/root
      - ${HOST_HOME}/.claude:/root/.claude
      - ./:/workspace
    stdin_open: true
    tty: true
    ports:
      - "3000:3000"
      - "5173:5173"
      - "8080:8080"
      - "8000:8000"

volumes:
  home:
YAML
        echo "Created $COMPOSE_FILE"
    fi

    if [[ ! -f .sandy.env ]]; then
        cat > .sandy.env <<'ENV'
# Sandy container environment variables
# These override the project .env inside the container
# ANTHROPIC_API_KEY=sk-ant-...
# PGUSER=admin
# PGPASSWORD=...
ENV
        echo "Created .sandy.env"
    fi

    # Update .gitignore
    touch .gitignore
    for entry in ".sandy.env" "$COMPOSE_FILE"; do
        if ! grep -qxF "$entry" .gitignore; then
            echo "$entry" >> .gitignore
            echo "Added $entry to .gitignore"
        fi
    done

    echo "Ready. Run 'sandy up' to start."
}

check_env() {
    if [[ ! -f .sandy.env ]]; then
        echo "Warning: .sandy.env not found. Container will start with no sandy env vars."
        return
    fi

    # Extract variable names (lines that aren't comments or blank, take left of =)
    local vars
    vars=$(grep -v '^\s*#' .sandy.env | grep -v '^\s*$' | cut -d= -f1 || true)

    if [[ -z "$vars" ]]; then
        echo "Warning: .sandy.env has no variables set."
    else
        echo "Env vars loaded:"
        echo "$vars" | while read -r name; do echo "  $name"; done
    fi
}

cmd_up() {
    require_compose
    check_env
    compose up -d
    echo "Container started. Run 'sandy shell' to connect."
}

cmd_down() {
    require_compose
    compose down
}

cmd_shell() {
    require_compose
    compose exec sandy bash
}

cmd_rebuild() {
    require_compose
    compose build --no-cache
    compose up -d
    echo "Rebuilt and started. Run 'sandy shell' to connect."
}

cmd_destroy() {
    require_compose
    compose down -v
    rm -f "$COMPOSE_FILE"
    echo "Destroyed container, volumes, and $COMPOSE_FILE."
    echo ".sandy.env was kept. Run 'sandy init' to start fresh."
}

case "${1:-up}" in
    init)    cmd_init ;;
    up)      cmd_up ;;
    down)    cmd_down ;;
    shell)   cmd_shell ;;
    rebuild) cmd_rebuild ;;
    destroy) cmd_destroy ;;
    -h|--help) usage ;;
    *)       usage ;;
esac
