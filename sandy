#!/usr/bin/env bash
set -euo pipefail

SANDY_HOME="${SANDY_HOME:-$HOME/.sandy}"
COMPOSE_FILE="sandy-compose.yml"
ENV_FILE=".sandy.env"
REPO="pinegoose/sandy"
BRANCH="master"
BASE_URL="https://raw.githubusercontent.com/${REPO}/${BRANCH}"

usage() {
    cat <<EOF
Usage: sandy <command>

Commands:
  init      Set up sandy in the current project directory
  up        Start the dev container (default if no command given)
  down      Stop the dev container
  shell     Open a shell in the running container
  rebuild   Rebuild the container image from scratch
  destroy   Stop container, remove volumes, and remove sandy-compose.yml
  upgrade   Update sandy to the latest version

EOF
    exit 1
}

find_compose() {
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/$COMPOSE_FILE" ]]; then
            if [[ "$dir" != "$PWD" ]]; then
                echo "Using $COMPOSE_FILE in $dir"
            fi
            cd "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    echo "Error: $COMPOSE_FILE not found in any parent directory." >&2
    echo "Run 'sandy init' in your project root first." >&2
    exit 1
}

compose() {
    SANDY_HOME="$SANDY_HOME" HOST_HOME="$HOME" docker compose -f "$COMPOSE_FILE" "$@"
}

cmd_init() {
    if [[ ! -f "$SANDY_HOME/Dockerfile" ]]; then
        echo "Error: Sandy not installed. Run install.sh first." >&2
        exit 1
    fi

    if [[ -f "$COMPOSE_FILE" ]]; then
        echo "$COMPOSE_FILE already exists, skipping."
    else
        cat > "$COMPOSE_FILE" <<'YAML'
services:
  sandy:
    build: ${SANDY_HOME}
    restart: unless-stopped
    env_file:
      - .sandy.env
    volumes:
      - ${HOST_HOME}/.claude:/root/.claude
      - go-mod-cache:/root/go/pkg/mod
      - go-build-cache:/root/.cache/go-build
      - pnpm-cache:/root/.local/share/pnpm/store
      - npm-cache:/root/.npm
      - pip-cache:/root/.cache/pip
      - ./:/workspace
    stdin_open: true
    tty: true
    ports:
      - "3000:3000"
      - "5173:5173"
      - "8080:8080"
      - "8000:8000"

volumes:
  go-mod-cache:
  go-build-cache:
  pnpm-cache:
  npm-cache:
  pip-cache:
YAML
        echo "Created $COMPOSE_FILE"
    fi

    if [[ ! -f "$ENV_FILE" ]]; then
        cat > "$ENV_FILE" <<'ENV'
# Sandy container environment variables
# These override the project .env inside the container
# ANTHROPIC_API_KEY=sk-ant-...
# PGUSER=admin
# PGPASSWORD=...
ENV
        echo "Created $ENV_FILE"
    fi

    # Update .gitignore
    touch .gitignore
    for entry in "$ENV_FILE" "$COMPOSE_FILE"; do
        if ! grep -qxF "$entry" .gitignore; then
            echo "$entry" >> .gitignore
            echo "Added $entry to .gitignore"
        fi
    done

    echo "Ready. Run 'sandy up' to start."
}

check_env() {
    if [[ ! -f "$ENV_FILE" ]]; then
        echo "Warning: $ENV_FILE not found. Creating empty file."
        touch "$ENV_FILE"
        return
    fi

    local vars
    vars=$(grep -v '^\s*#' "$ENV_FILE" | grep -v '^\s*$' | cut -d= -f1 || true)

    if [[ -z "$vars" ]]; then
        echo "Warning: $ENV_FILE has no variables set."
    else
        echo "Env vars loaded:"
        echo "$vars" | while read -r name; do echo "  $name"; done
    fi
}

cmd_up() {
    find_compose
    check_env
    compose up -d
    echo "Container started. Run 'sandy shell' to connect."
}

cmd_down() {
    find_compose
    compose down
}

cmd_shell() {
    find_compose
    compose exec sandy bash
}

cmd_rebuild() {
    find_compose
    check_env
    compose build --no-cache
    compose up -d
    echo "Rebuilt and started. Run 'sandy shell' to connect."
}

cmd_destroy() {
    find_compose
    compose down -v
    rm -f "$COMPOSE_FILE"
    echo "Destroyed container, volumes, and $COMPOSE_FILE."
    echo "$ENV_FILE was kept. Run 'sandy init' to start fresh."
}

cmd_upgrade() {
    echo "Upgrading sandy..."
    curl -fsSL "${BASE_URL}/Dockerfile" -o "$SANDY_HOME/Dockerfile"
    curl -fsSL "${BASE_URL}/sandy" -o "/usr/local/bin/sandy"
    chmod +x "/usr/local/bin/sandy"
    echo "Upgraded. Run 'sandy rebuild' in your project to pick up Dockerfile changes."
}

case "${1:-up}" in
    init)    cmd_init ;;
    up)      cmd_up ;;
    down)    cmd_down ;;
    shell)   cmd_shell ;;
    rebuild) cmd_rebuild ;;
    destroy) cmd_destroy ;;
    upgrade) cmd_upgrade ;;
    -h|--help) usage ;;
    *)       usage ;;
esac
